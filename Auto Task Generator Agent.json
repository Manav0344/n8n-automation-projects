    {
      "parameters": {
        "jsCode": "let data;\n\ntry {\n  data = JSON.parse($json.output);\n} catch (error) {\n  data = {};\n}\n\n// generate automatic chat id\nconst chatId = \"chat_\" + Date.now() + \"_\" + Math.floor(Math.random() * 10000);\n\nreturn [\n{\njson: {\nTask: data.Task || \"\",\nDueDate: data.DueDate || \"\",\nType: data.Type || \"other\",\nPriority: data.Priority || \"medium\",\nNotes: data.Notes || \"\",\nSourceText: data.SourceText || \"\",\nCreatedAt: data.CreatedAt || new Date().toISOString(),\nChatId: chatId\n}\n}\n];"
      },
